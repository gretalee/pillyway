{
  "name": "pillyway",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "install": "yarn --cwd apps/frontend install && yarn --cwd apps/backend install && yarn --cwd apps/e2e install",
    "dev:backend": "yarn --cwd apps/backend start:dev",
    "dev:frontend": "NODE_PATH=apps/frontend/node_modules yarn --cwd apps/frontend dev",
    "dev:frontend:test": "NODE_PATH=apps/frontend/node_modules NODE_ENV=test yarn --cwd apps/frontend dev",
    "build:backend": "yarn --cwd apps/backend build",
    "build:frontend": "yarn --cwd apps/frontend build",
    "test:e2e": "yarn build:frontend && yarn --cwd apps/e2e test",
    "test:e2e:ui": "yarn build:frontend && yarn --cwd apps/e2e test:ui",
    "lint": "yarn --cwd apps/backend lint && yarn --cwd apps/frontend lint",
    "test": "yarn test:backend && yarn test:frontend",
    "test:backend": "yarn --cwd apps/backend test",
    "test:frontend": "yarn --cwd apps/frontend test",
    "prettier:frontend": "yarn --cwd apps/frontend prettier --write .",
    "ts:backend": "yarn --cwd apps/backend tsc",
    "ts:frontend": "yarn --cwd apps/frontend tsc",
    "ts": "yarn ts:backend && yarn ts:frontend",
    "db:migrate": "yarn --cwd apps/backend prisma:migrate:deploy",
    "seed:camino": "yarn --cwd apps/backend seed:camino",
    "seed:camino:prod": "yarn --cwd apps/backend seed:camino:prod",
    "seed:franziskusweg": "yarn --cwd apps/backend seed:franziskusweg",
    "seed:franziskusweg:prod": "yarn --cwd apps/backend seed:franziskusweg:prod",
    "db:backup:dev": "yarn --cwd apps/backend db:backup:dev",
    "db:backup:prod": "yarn --cwd apps/backend db:backup:prod",
    "db:restore:dev": "yarn --cwd apps/backend db:restore:dev"
  },
  "engines": {
    "node": ">=24.14.0"
  }
}
