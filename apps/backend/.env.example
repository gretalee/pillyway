PORT=3033
FRONTEND_URL=http://localhost:3000

# Database with Prisma
#
# LOCAL DEVELOPMENT
#   `supabase start`
#    `yarn workspace @pillyway/backend prisma:migrate:dev
#
#   DATABASE_URL and DIRECT_URL are the same — no pooler used locally.
#   Port 54322 is Supabase's local PostgreSQL port (NOT 5432).
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

KINDE_ISSUER_URL=https://pillyway.kinde.com

# Supabase Storage (used by UploadsService for image hosting)
# SUPABASE_URL      — API base URL (local: http://127.0.0.1:54321, cloud: https://<ref>.supabase.co)
# SUPABASE_S3_URL   — S3-compatible endpoint (from dashboard → Storage → S3 Access → URL)
# SUPABASE_S3_REGION, SUPABASE_S3_ACCESS_KEY, SUPABASE_S3_SECRET_KEY — from same section
# SUPABASE_STORAGE_BUCKET — exact bucket ID shown in Storage dashboard
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_S3_URL=http://127.0.0.1:54321/storage/v1/s3
SUPABASE_S3_REGION=local
SUPABASE_S3_ACCESS_KEY=<access-key>
SUPABASE_S3_SECRET_KEY=<secret-key>
SUPABASE_STORAGE_BUCKET=<bucket-id>
# Private S3 bucket for GPX files (same project credentials as SUPABASE_STORAGE_BUCKET)
SUPABASE_STORAGE_BUCKET_GPX=pilly_gpx

# Deployment secrets
HETZNER_HOST=your.server.ip
HETZNER_USER=any-ssh-user
SSH_PRIVATE_KEY="-----BEGIN ...-----"

