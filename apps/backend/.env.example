PORT=3033
FRONTEND_URL=http://localhost:3000

# Database with Prisma
#
# LOCAL DEVELOPMENT
#   `supabase start`
#    `yarn workspace @pillyway/backend prisma:migrate:dev
#
#   DATABASE_URL and DIRECT_URL are the same — no pooler used locally.
#   Port 54322 is Supabase's local PostgreSQL port (NOT 5432).
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

KINDE_ISSUER_URL=https://pillyway.kinde.com

# Supabase Storage (used by UploadsService for image hosting)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_STORAGE_BUCKET=pillyway-images

# Deployment secrets
HETZNER_HOST=your.server.ip
HETZNER_USER=any-ssh-user
SSH_PRIVATE_KEY="-----BEGIN ...-----"

