# Copy to .env and fill in values

PORT=3033

# Database — Prisma connection strings
#
# LOCAL DEVELOPMENT (Supabase local via `supabase start`):
#   DATABASE_URL and DIRECT_URL are the same — no pooler used locally.
#   Port 54322 is Supabase's local PostgreSQL port (NOT 5432).
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
#
# SUPABASE CLOUD (production / staging):
#   DATABASE_URL  → Supavisor session-mode pooler (port 5432, no pgbouncer flag needed for Prisma).
#                   Found in: Supabase Dashboard → Project Settings → Database → Connection string → Session mode
#   DIRECT_URL    → Direct connection, bypasses pooler; required by `prisma migrate`.
#                   Found in: Supabase Dashboard → Project Settings → Database → Connection string → Direct connection
#
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"


# Frontend origin allowed by CORS (e.g. http://localhost:3000 in dev)
FRONTEND_URL=http://localhost:3000

# Kinde — your Kinde domain (e.g. https://yourapp.kinde.com)
KINDE_ISSUER_URL=https://<your-domain>.kinde.com
