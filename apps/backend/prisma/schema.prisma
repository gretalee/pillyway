generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Camino {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  verified    Boolean  @default(false)
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  caminoPointOrder CaminoPointOrder[]

  @@unique([name])
  @@map("caminos")
}

model CaminoPoint {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  country     String
  description String?
  slug        String   @unique
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  caminoPointOrder CaminoPointOrder[]
  stagesAsStart    Stage[]            @relation("StageStart")
  stagesAsEnd      Stage[]            @relation("StageEnd")
  accommodations   Accommodation[]
  sights           Sight[]

  @@unique([name, country])
  @@map("camino_points")
}

model Stage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  startPointId String   @map("start_point_id") @db.Uuid
  endPointId   String   @map("end_point_id") @db.Uuid
  distance     Float?
  description  String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  startPoint CaminoPoint @relation("StageStart", fields: [startPointId], references: [id])
  endPoint   CaminoPoint @relation("StageEnd", fields: [endPointId], references: [id])

  @@unique([startPointId, endPointId])
  @@map("stages")
}

model CaminoPointOrder {
  caminoId      String @map("camino_id") @db.Uuid
  caminoPointId String @map("camino_point_id") @db.Uuid
  position      Int

  camino      Camino      @relation(fields: [caminoId], references: [id], onDelete: Cascade)
  caminoPoint CaminoPoint @relation(fields: [caminoPointId], references: [id], onDelete: Cascade)

  @@id([caminoId, caminoPointId])
  @@unique([caminoId, position])
  @@map("camino_point_order")
}

model Accommodation {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caminoPointId String   @map("camino_point_id") @db.Uuid
  name          String
  description   String?
  imageUrls     String[] @default([]) @map("image_urls")
  verified      Boolean  @default(false)
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  caminoPoint CaminoPoint @relation(fields: [caminoPointId], references: [id], onDelete: Cascade)

  @@map("accommodations")
}

model Sight {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caminoPointId String   @map("camino_point_id") @db.Uuid
  name          String
  description   String?
  imageUrls     String[] @map("image_urls")
  verified      Boolean  @default(false)
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  caminoPoint CaminoPoint @relation(fields: [caminoPointId], references: [id], onDelete: Cascade)

  @@map("sights")
}
