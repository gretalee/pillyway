generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Camino {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  verified    Boolean  @default(false)
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  caminoPointOrder CaminoPointOrder[]
  votes            CaminoVote[]
  pictures         CaminoPicture[]

  @@unique([name])
  @@map("caminos")
}

model CaminoVote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caminoId  String   @map("camino_id") @db.Uuid
  userId    String   @map("user_id")
  vote      Boolean
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  camino Camino @relation(fields: [caminoId], references: [id], onDelete: Cascade)

  @@unique([caminoId, userId])
  @@map("camino_votes")
}

model CaminoPoint {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  country     String
  description String?
  slug        String   @unique
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  caminoPointOrder CaminoPointOrder[]
  stagesAsStart    Stage[]            @relation("StageStart")
  stagesAsEnd      Stage[]            @relation("StageEnd")
  accommodations   Accommodation[]
  sights           Sight[]

  @@unique([name, country])
  @@map("camino_points")
}

model Stage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  startPointId String   @map("start_point_id") @db.Uuid
  endPointId   String   @map("end_point_id") @db.Uuid
  distance     Float?
  description  String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  startPoint CaminoPoint @relation("StageStart", fields: [startPointId], references: [id])
  endPoint   CaminoPoint @relation("StageEnd", fields: [endPointId], references: [id])

  @@unique([startPointId, endPointId])
  @@map("stages")
}

model CaminoPointOrder {
  caminoId      String @map("camino_id") @db.Uuid
  caminoPointId String @map("camino_point_id") @db.Uuid
  position      Int

  camino      Camino      @relation(fields: [caminoId], references: [id], onDelete: Cascade)
  caminoPoint CaminoPoint @relation(fields: [caminoPointId], references: [id], onDelete: Cascade)

  @@id([caminoId, caminoPointId])
  @@unique([caminoId, position])
  @@map("camino_point_order")
}

enum AccommodationType {
  hostel
  monastery
  b_and_b
  hotel
  apartment
  private_room
  church
}

enum PriceRange {
  budget
  moderate
  comfortable
  luxury
}

model Accommodation {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caminoPointId  String            @map("camino_point_id") @db.Uuid
  name           String
  description    String?
  imageUrls      String[]          @default([]) @map("image_urls")
  verified       Boolean           @default(false)
  type           AccommodationType @default(hostel)
  email          String?
  website        String?
  addressStreet  String?           @map("address_street")
  addressZip     String?           @map("address_zip")
  addressCity    String?           @map("address_city")
  addressCountry String?           @map("address_country")
  priceRange     PriceRange?       @map("price_range")
  phone          String?           @db.VarChar(30)
  createdBy      String            @map("created_by")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)

  caminoPoint CaminoPoint @relation(fields: [caminoPointId], references: [id], onDelete: Cascade)

  @@map("accommodations")
}

model CaminoPicture {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caminoId   String   @map("camino_id") @db.Uuid
  uploadedBy String   @map("uploaded_by")
  url        String
  isPrimary  Boolean  @default(false) @map("is_primary")
  position   Int?
  label      String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  camino Camino @relation(fields: [caminoId], references: [id], onDelete: Cascade)

  @@index([caminoId, position, createdAt])
  @@index([uploadedBy])
  @@map("camino_pictures")
}

model Sight {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caminoPointId String   @map("camino_point_id") @db.Uuid
  name          String
  description   String?
  imageUrls     String[] @map("image_urls")
  verified      Boolean  @default(false)
  address       String?
  latitude      Float?
  longitude     Float?
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  caminoPoint CaminoPoint @relation(fields: [caminoPointId], references: [id], onDelete: Cascade)

  @@map("sights")
}

model UserEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType  String   @map("event_type") @db.VarChar(100)
  userId     String?  @map("user_id")
  payload    Json     @default("{}")
  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  @@index([eventType])
  @@index([userId])
  @@index([occurredAt(sort: Desc)])
  @@map("user_events")
}
