generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Camino {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  verified    Boolean  @default(false)
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  caminoPointOrder CaminoPointOrder[]

  @@unique([name])
  @@map("caminos")
}

model CaminoPoint {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  country     String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  caminoPointOrder CaminoPointOrder[]

  @@unique([name, country])
  @@map("camino_points")
}

model CaminoPointOrder {
  caminoId      String @map("camino_id") @db.Uuid
  caminoPointId String @map("camino_point_id") @db.Uuid
  position      Int

  camino      Camino      @relation(fields: [caminoId], references: [id], onDelete: Cascade)
  caminoPoint CaminoPoint @relation(fields: [caminoPointId], references: [id], onDelete: Cascade)

  @@id([caminoId, caminoPointId])
  @@unique([caminoId, position])
  @@map("camino_point_order")
}
