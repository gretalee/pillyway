# URL of the running frontend application.
# Start the app locally before running tests (e.g. yarn dev:frontend).
E2E_BASE_URL=http://localhost:3000

# URL of the running backend API.
# Start the backend locally before running tests (e.g. yarn dev:backend).
NEXT_PUBLIC_API_URL=http://localhost:3033/api

# Credentials for a test account that has the "pilgrim" (Route Editor) role.
# Required for all authenticated pilgrim tests.
E2E_PILGRIM_EMAIL=
E2E_PILGRIM_PASSWORD=

# Credentials for a test account that does NOT have the pilgrim role but owns
# at least one seeded camino in the test database (createdBy = this user's ID).
# Required for owner-specific tests.
E2E_OWNER_EMAIL=
E2E_OWNER_PASSWORD=
